#################################################
# GLOBAL (applies to everything inside app/)
#################################################

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment files (ignore everywhere)
**/.env
**/.env.*
!**/.env.example

# Dependencies (ignore everywhere)
**/node_modules/

# Build output (ignore everywhere)
**/dist/
**/build/
**/coverage/

# Caches (Vite, Parcel, etc)
**/.cache/
**/.vite/
**/.parcel-cache/

# TypeScript
**/*.tsbuildinfo

# Temporary files
*.tmp
**/*.tmp
*.temp
**/*.temp
*.swp
**/*.swp
*.swo
**/*.swo

# IDE
.vscode/
**/.vscode/
.idea/
**/.idea/

#################################################
# Backend specific runtime folders
#################################################

backend/uploads/
backend/tmp/
backend/logs/

#################################################
# Frontend specific cache files
#################################################

frontend/.eslintcache
frontend/.stylelintcache
.vercel
