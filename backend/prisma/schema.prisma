generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Status {
  ACTIVE
  INACTIVE
}

model Instituicao {
  id         Int      @id @default(autoincrement())
  nome       String
  descricao  String?
  endereco   String
  registrada DateTime @default(now())
  status     Status   @default(ACTIVE)
  deletedAt  DateTime?

  departamentos Departamento[]

  @@index([deletedAt])
}

model Departamento {
  id         Int      @id @default(autoincrement())
  nome       String
  descricao  String?
  registrado DateTime @default(now())
  status     Status   @default(ACTIVE)
  deletedAt  DateTime?

  instituicaoId Int
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Restrict)

  salas Sala[]

  @@index([deletedAt])
}

model Sala {
  id         Int    @id @default(autoincrement())
  numeroSala String
  tipoSala   String
  deletedAt  DateTime?

  departamentoId Int?
  departamento   Departamento? @relation(fields: [departamentoId], references: [id], onDelete: Restrict)

  itens Item[]

  @@index([deletedAt])
}

model Cargo {
  id         Int     @id @default(autoincrement())
  nome       String  @unique
  descricao  String?
  permissoes Json?
  deletedAt  DateTime?

  utilizadores Utilizador[]

  @@index([deletedAt])
}

model Utilizador {
  id        Int     @id @default(autoincrement())
  nome      String
  email     String  @unique
  password  String
  descricao String?
  deletedAt DateTime?

  cargoId Int
  cargo   Cargo @relation(fields: [cargoId], references: [id], onDelete: Restrict)

  registos Registo[]

  @@index([deletedAt])
}

model Categoria {
  id        Int     @id @default(autoincrement())
  nome      String  @unique
  descricao String?
  deletedAt DateTime?

  itens Item[]

  @@index([deletedAt])
}

model Condicao {
  id        Int     @id @default(autoincrement())
  nome      String  @unique
  descricao String?
  deletedAt DateTime?

  itens Item[]

  @@index([deletedAt])
}

model Item {
  id         Int      @id @default(autoincrement())
  nome       String
  descricao  String?
  quantidade Int      @default(1)
  registrado DateTime @default(now())
  status     Status   @default(ACTIVE)
  deletedAt  DateTime?

  // Categoria: automática via trigger
  categoriaId Int?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  // Condição: obrigatória (integridade forte)
  condicaoId Int
  condicao   Condicao @relation(fields: [condicaoId], references: [id], onDelete: Restrict)

  // Sala: automática via trigger
  salaId Int?
  sala   Sala? @relation(fields: [salaId], references: [id], onDelete: SetNull)

  registos Registo[]

  @@index([deletedAt])
  @@index([categoriaId])
  @@index([salaId])
}

model Registo {
  id         Int      @id @default(autoincrement())
  quantidade Int
  registrado DateTime @default(now())
  deletedAt  DateTime?

  itemId Int
  item   Item @relation(fields: [itemId], references: [id], onDelete: Restrict)

  utilizadorId Int
  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Restrict)

  @@index([deletedAt])
}