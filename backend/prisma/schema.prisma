generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Instituicao {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  endereco  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  departamentos Departamento[]
  cargos        Cargo[]
  utilizadores  Utilizador[]
  categorias    Categoria[]

  @@index([deletedAt])
}

model Departamento {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  instituicaoId Int
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Restrict)

  salas Sala[]

  @@index([deletedAt])
}

model Sala {
  id         Int    @id @default(autoincrement())
  numeroSala String
  tipoSala   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  departamentoId Int?
  departamento   Departamento? @relation(fields: [departamentoId], references: [id], onDelete: Restrict)

  itens Item[]

  @@index([deletedAt])
}

model Cargo {
  id        Int     @id @default(autoincrement())
  nome      String
  descricao String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  instituicaoId Int
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Restrict)

  utilizadores Utilizador[]
  permissoes   CargoPermissao[]

  @@unique([nome, instituicaoId])
  @@index([deletedAt])
}

model Utilizador {
  id        Int     @id @default(autoincrement())
  nome      String
  email     String  @unique
  password  String
  descricao String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  instituicaoId Int
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Restrict)

  cargoId Int
  cargo   Cargo @relation(fields: [cargoId], references: [id], onDelete: Restrict)

  registos    Registo[]
  permissoes  UtilizadorPermissao[]

  @@index([deletedAt])
}

model Permissao {
  id   Int    @id @default(autoincrement())
  nome String @unique
  descricao String?

  cargos       CargoPermissao[]
  utilizadores UtilizadorPermissao[]
}

model CargoPermissao {
  cargoId     Int
  permissaoId Int

  cargo     Cargo     @relation(fields: [cargoId], references: [id], onDelete: Restrict)
  permissao Permissao @relation(fields: [permissaoId], references: [id], onDelete: Restrict)

  @@id([cargoId, permissaoId])
}

model UtilizadorPermissao {
  utilizadorId Int
  permissaoId  Int
  permitido    Boolean @default(true)

  utilizador Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Restrict)
  permissao  Permissao  @relation(fields: [permissaoId], references: [id], onDelete: Restrict)

  @@id([utilizadorId, permissaoId])
}

model Categoria {
  id        Int     @id @default(autoincrement())
  nome      String
  descricao String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  instituicaoId Int
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Restrict)

  itens Item[]

  @@unique([nome, instituicaoId])
  @@index([deletedAt])
}

model Condicao {
  id        Int     @id @default(autoincrement())
  nome      String  @unique
  descricao String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  itens Item[]

  @@index([deletedAt])
}

model Item {
  id         Int      @id @default(autoincrement())
  nome       String
  descricao  String?
  quantidade Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  categoriaId Int?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  condicaoId Int
  condicao   Condicao @relation(fields: [condicaoId], references: [id], onDelete: Restrict)

  salaId Int?
  sala   Sala? @relation(fields: [salaId], references: [id], onDelete: SetNull)

  registos Registo[]

  @@index([deletedAt])
  @@index([categoriaId])
  @@index([salaId])
}

model Registo {
  id         Int      @id @default(autoincrement())
  quantidade Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  itemId Int
  item   Item @relation(fields: [itemId], references: [id], onDelete: Restrict)

  utilizadorId Int
  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Restrict)

  @@index([deletedAt])
  @@index([itemId, createdAt])
  @@index([utilizadorId, createdAt])
}